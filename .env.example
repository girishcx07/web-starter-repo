# Copy this file to `.env` and point the web apps at your external backend API.

API_URL="https://jsonplaceholder.typicode.com"
VITE_PUBLIC_API_URL="https://jsonplaceholder.typicode.com"
NEXT_PUBLIC_API_URL="https://jsonplaceholder.typicode.com"

NEXT_PUBLIC_APP_URL="http://localhost:3000"
VITE_PUBLIC_TANSTACK_APP_URL="http://localhost:3001"
VITE_PUBLIC_REACT_ROUTER_APP_URL="http://localhost:3002"

# Generate with: openssl rand -base64 32
AUTH_SECRET="supersecret"

# Optional local demo login for the native auth handlers.
AUTH_DEMO_EMAIL="demo@example.com"
AUTH_DEMO_PASSWORD="password"
AUTH_DEMO_NAME="Demo user"
