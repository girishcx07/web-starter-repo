{
  "name": "@acme/react-router",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm with-env react-router build",
    "clean": "git clean -xdf .cache .react-router build .turbo node_modules",
    "dev": "pnpm with-env node server.js",
    "format": "prettier --check . --ignore-path ../../.gitignore --ignore-path .prettierignore",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "start": "node server.js",
    "typecheck": "react-router typegen && tsc -b",
    "with-env": "dotenv -e ../../.env --"
  },
  "dependencies": {
    "@acme/api": "workspace:*",
    "@acme/auth": "workspace:*",
    "@acme/types": "workspace:*",
    "@acme/ui": "workspace:*",
    "@acme/utils": "workspace:*",
    "@react-router/express": "7.15.0",
    "@react-router/node": "7.15.0",
    "@t3-oss/env-core": "^0.13.8",
    "@tanstack/react-form": "catalog:",
    "@tanstack/react-query": "catalog:",
    "compression": "^1.8.1",
    "express": "^5.2.1",
    "isbot": "^5.1.36",
    "morgan": "^1.10.1",
    "react": "catalog:react19",
    "react-dom": "catalog:react19",
    "react-router": "7.15.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@acme/eslint-config": "workspace:*",
    "@acme/prettier-config": "workspace:*",
    "@acme/tailwind-config": "workspace:*",
    "@acme/tsconfig": "workspace:*",
    "@react-router/dev": "7.15.0",
    "@tailwindcss/vite": "catalog:",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/express-serve-static-core": "^5.1.1",
    "@types/morgan": "^1.9.10",
    "@types/node": "catalog:",
    "@types/react": "catalog:react19",
    "@types/react-dom": "catalog:react19",
    "@vitejs/plugin-react": "catalog:",
    "cross-env": "^10.0.0",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "prettier": "@acme/prettier-config"
}
