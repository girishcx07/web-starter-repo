{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "tasks": {
    "topo": {
      "dependsOn": ["^topo"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".cache/tsbuildinfo.json", "dist/**"]
    },
    "dev": {
      "dependsOn": ["^dev"],
      "cache": false,
      "persistent": false
    },
    "format": {
      "outputs": [".cache/.prettiercache"],
      "outputLogs": "new-only"
    },
    "lint": {
      "dependsOn": ["^topo", "^build"],
      "outputs": [".cache/.eslintcache"]
    },
    "typecheck": {
      "dependsOn": ["^topo", "^build"],
      "outputs": [".cache/tsbuildinfo.json"]
    },
    "clean": {
      "cache": false
    },
    "//#clean": {
      "cache": false
    },
    "push": {
      "cache": false,
      "interactive": true
    },
    "studio": {
      "cache": false,
      "persistent": true
    },
    "ui-add": {
      "cache": false,
      "interactive": true
    }
  },
  "globalEnv": [
    "API_URL",
    "VITE_PUBLIC_API_URL",
    "VITE_PUBLIC_TANSTACK_APP_URL",
    "VITE_PUBLIC_REACT_ROUTER_APP_URL",
    "NEXT_PUBLIC_API_URL",
    "NEXT_PUBLIC_APP_URL",
    "AUTH_SECRET",
    "AUTH_DEMO_EMAIL",
    "AUTH_DEMO_PASSWORD",
    "AUTH_DEMO_NAME",
    "PORT",
    "TURBO_DAEMON"
  ],
  "globalPassThroughEnv": [
    "NODE_ENV",
    "CI",
    "DEV",
    "npm_lifecycle_event"
  ]
}
